# Скопируй этот файл в .env и заполни своими данными

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Chat ID (твой личный или группы)
# Узнать свой ID: написать @userinfobot
TELEGRAM_CHAT_ID=-100123456789

# (Опционально) Birdeye API key — fallback для holders count на Solana,
# если GeckoTerminal вернул 0. Получить: https://bds.birdeye.so
BIRDEYE_API_KEY=

# (Опционально) Helius API key — для настоящего smart-money wallet tracking.
# Получить: https://dev.helius.xyz
HELIUS_API_KEY=

# (Опционально) Путь к SQLite базе с WAYNE_PIRATE smart-money кошельками —
# если указан, детектор будет бустить score при покупке от этих кошельков.
# Для локального Mac — путь к проду бота:
#   /Users/mac/Documents/WAYNE/WAYNE_PIRATE/solana-smart-money-bot/data/bot.db
WAYAN_SM_DB_PATH=
